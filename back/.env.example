# Local Docker validation
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/artlog_db
SPRING_DATASOURCE_USERNAME=artlog_user
SPRING_DATASOURCE_PASSWORD=artlog_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

JWT_SECRET=change-me-to-a-very-long-random-string-for-jwt-signing
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600

FRONTEND_BASE_URL=http://localhost:5173
OAUTH2_AUTHORIZED_REDIRECT_URI=http://localhost:5173/auth/callback
OAUTH2_FAILURE_REDIRECT_URI=http://localhost:5173/auth/login
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_ISSUER=https://appleid.apple.com
APPLE_PUBLIC_KEY_URL=https://appleid.apple.com/auth/keys
